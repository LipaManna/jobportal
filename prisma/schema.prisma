// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  applicant
  employer
  admin
}

enum Marital_Status {
  single
  married
  divorced
  widowed
}

enum Gender {
  male
  female
  other
}

enum Education {
  high_school
  diploma
  bachelor
  master
  phd
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String
  name              String
  username          String    @unique
  role              Role    @default(applicant)
  avatar_url        String?
  email_verified    Boolean   @default(false)
  email_verified_at DateTime?
  phone_number      String?
  is_active         Boolean   @default(true)
  deleted_at        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  session           Session?
  employer          Employer?
  applicant         Applicant?
}


model Session {
  id          Int      @id @default(autoincrement())
  user_id     Int      @unique
  user_agent  String?
  ip_address  String?
  session_id  String   @unique
  expires_at  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Employer {
  user_id Int @id
  company_name String
  company_logo_url String?
  company_description String?
  company_banner_image_url String?
  org_type String?
  company_website String?
  company_phone String?
  company_email String?
  company_location String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?
  year_of_establishment Int?
  employee_size String?
  

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Applicant {
  user_id Int @id
  biography String
  date_of_birth DateTime
  nationality String?
  marital_status Marital_Status
  gender  Gender
  experience String
  education Education
  website_url String?
  location String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}